doctype html
html
    head
        title Scrap Asset
        link(rel="stylesheet", href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css")
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    body
        .container
            h1 Scrap Asset
            form(action="/scrap" method="post")
                .mb-3
                    label(for="assetId") Select Asset:
                    select#assetId.form-select(name="assetId" required)
                        option(value="" selected disabled) Select Asset
                        each asset in assets
                            option(value=asset.id) #{asset.name}
                .mb-3
                    label(for="reason") Reason for Scrapping:
                    input#reason.form-control(type="text" name="reason" placeholder="Enter reason (e.g., upgrade, repair)" required)
                button.btn.btn-danger(type="submit") Scrap Asset

            