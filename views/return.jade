doctype html
html
    head
        title Return Asset
        link(rel="stylesheet", href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css")
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    body
        .container
            h1 Return Asset
            form(action="/return" method="post")
                .mb-3
                    label(for="assetId") Select Asset to Return:
                    select#assetId.form-select(name="assetId" required)
                        option(value="" selected disabled) Select Asset
                        each asset in issueAsset
                            option(value=asset.id) #{asset.name}
                .mb-3
                    label(for="reason") Reason for Return:
                    select#reason.form-select(name="reason" required)
                        option(value="" selected disabled) Select Reason
                        option(value="Upgrade") Upgrade
                        option(value="Repair") Repair
                        option(value="Resignation") Resignation
                        option(value="Other") Other
                button.btn.btn-primary(type="submit") Return Asset

            