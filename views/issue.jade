doctype html
html
    head
        title Issue Asset
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    body
        .container
            h1.text-center.mt-3 Issue Asset
            form(action="/issue" method="post")
                .mb-3
                    label(for="assetId") Select Asset:
                    select#assetId.form-select(name="assetId" required)
                        option(value="" selected disabled) Select Asset
                        each asset in assets
                            option(value=asset.id) #{asset.name}
                .mb-3
                    label(for="employeeId") Assign to Employee:
                    select#employeeId.form-select(name="employeeId" required)
                        option(value="" selected disabled) Select Employee 
                        each employee in employees
                            option(value=employee.id) #{employee.name}
                button.btn.btn-primary(type="submit") Issue Asset

            